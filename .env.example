# ── App ──
APP_ENV=dev
LOG_LEVEL=info

# ── WhatsApp ──
TOKEN_WHATSAPP=
BASE_URL_GRAPH_API=
PHONE_NUMBER_ID=

# ── Email (SMTP) ──
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_HOST=

# ── Database (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=verify_auth
DB_SSLMODE=disable

# ── JWT ──
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
